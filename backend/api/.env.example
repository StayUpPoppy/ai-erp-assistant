# Datynk 本机联调：复制本文件为同目录下的 `.env` 后重启 API（`npm run dev:api`）。
# 勿将 `.env` 提交到 Git。无 Token 时部分 GET 仍可能可用；写接口、客户保存通常需 Cookie 或 Token。
#
#   copy datynk-real.env.example .env   （PowerShell: Copy-Item）

# 建议本地先用 mock，避免误写真实 ERP
ERP_CLIENT_MODE=mock
ERP_BASE_URL=https://erp.datynk.com
ERP_WRITE_BASE_URL=https://erp.datynk.com
ERP_CUSTOMER_MATERIAL_DETAILS_BY_CUSTOMER_PATH=/api/customer-material/details-by-customer
ERP_AUTH_MODE=bearer
ERP_API_TOKEN=
ERP_TIMEOUT_SECONDS=20
ERP_CREATE_TIMEOUT_SECONDS=120


ERP_CREATE_BODY_STYLE=datynk_sale_order
ERP_CREATE_DRAFT_PATH=/api/sale-order/save-with-details
ERP_SOURCE_ATTACHMENT_ENABLED=false
ERP_SOURCE_ATTACHMENT_MAX_BYTES=31457280
ERP_ALLOW_EMPTY_DRAFT_URL=true
ERP_SKIP_UPSTREAM_VALIDATE=true

ERP_DATYNK_DEFAULT_ORG=英科1厂

ERP_SALE_ORDER_PAGE_PATH=/api/sale-order/page

# 主数据分页（与 Datynk 浏览器 Network 一致）。一厂/二厂只改聊天里的 org_id 或 ERP_DATYNK_DEFAULT_ORG，无需为二厂单独配 URL。
ERP_VENDORS_SEARCH_PATH=/api/supplier/page
ERP_VENDORS_SEARCH_QUERY_KEY=supplierName
ERP_MATERIALS_SEARCH_PATH=/api/material/page
ERP_WAREHOUSES_SEARCH_PATH=/api/warehouse/page
ERP_TAX_CODES_SEARCH_PATH=/api/tax/page
ERP_CUSTOMER_PAGE_ENABLED=true
ERP_CUSTOMER_PAGE_PATH=/api/customer/page
ERP_CUSTOMER_PAGE_KEYWORD_PARAM=customerName

ERP_QA_FALLBACK_WHEN_NO_INTENT=true

# 默认关闭客户保存，避免联调误写生产/测试数据；需要时改为 true
ERP_CUSTOMER_SAVE_ENABLED=false

# 若需登录后再调接口，改为 cookie_session 并填写：
# ERP_AUTH_MODE=cookie_session
# ERP_COOKIE_LOGIN_PATH=/api/auth/login
# ERP_LOGIN_USERNAME=
# ERP_LOGIN_PASSWORD=


# ===== Runtime / Queue / DB / LLM for PDF -> Preview -> Draft flow =====

API_HOST=127.0.0.1
API_PORT=8020
API_BASE_URL=http://127.0.0.1:8020

REDIS_URL=redis://127.0.0.1:6379/0
QUEUE_NAME=ingestion_jobs
INGESTION_QUEUE_FALLBACK_MODE=none

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=ai_erp_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/ai_erp_assistant

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-erp-assistant
MINIO_USE_SSL=false
OBJECT_STORAGE_REQUIRED=false
# ERP backend only. Generate a long random value in production; never expose it to browsers.
SOURCE_FILE_API_TOKEN=

APP_ENV=dev

# OCR
OCR_ENGINE=rapid
OCR_ENGINE_AUTO_FALLBACK=true
RAPIDOCR_INTRA_OP_NUM_THREADS=2
RAPIDOCR_MIN_CONFIDENCE=0.78
OCR_HEALTH_INIT_RAPID=false
PDF_RENDER_DPI=250
PDF_NATIVE_MIN_CHARS=48
PDF_OCR_MAX_PAGES=10
QWEN_VISION_EXTRACT_ENABLED=false
QWEN_VISION_FORCE_ALL=false
QWEN_VISION_MODEL=qwen3.7-plus
QWEN_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VISION_API_KEY=
QWEN_VISION_TIMEOUT_SECONDS=180
QWEN_VISION_MAX_PDF_PAGES=10
QWEN_VISION_RENDER_DPI=180
QWEN_VISION_FALLBACK_TO_LOCAL=true
QWEN_VISION_INCLUDE_LOCAL_TEXT=true
QWEN_VISION_LOCAL_TEXT_MAX_CHARS=12000
PADDLE_OCR_LANG=ch
PADDLE_OCR_USE_GPU=false
TESSERACT_OCR_LANG=chi_sim+eng
# 如果你本机已经装了 Tesseract，可按需取消注释并改成你的实际路径
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe

# LLM Preview Extract
LLM_EXTRACT_ENABLED=true
ASSISTANT_LLM_ROUTER_ENABLED=true
ASSISTANT_ROUTER_MAX_TOKENS=512
ASSISTANT_ROUTER_TIMEOUT_SECONDS=20
ASSISTANT_PLAIN_CHAT_FAST_PATH_ENABLED=true
# 可单独填写；留空时后端会复用 QWEN_VISION_API_KEY。
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.7-plus
LLM_REASONING_EFFORT=high
LLM_TIMEOUT_SECONDS=120
LLM_PROMPT_VERSION=qwen-order-preview-v1



