# Copy this file to deploy/ecs-panel/prod.env on the ECS server.
# Never commit prod.env with real keys.

APP_ENV=production
INSTALL_PADDLEOCR=false
DEBIAN_MIRROR=https://mirrors.aliyun.com/debian
NPM_REGISTRY=https://registry.npmmirror.com
PADDLEPADDLE_VERSION=3.2.0
PADDLEPADDLE_INDEX_URL=https://www.paddlepaddle.org.cn/packages/stable/cpu/

# Public site origin. Replace with your domain after binding one.
CORS_ALLOW_ORIGINS=http://111.170.173.2:8081
CORS_ALLOW_ORIGIN_REGEX=

# Queue
QUEUE_BACKEND=redis
QUEUE_NAME=ingestion_jobs
REDIS_URL=redis://redis:6379/0
WORKER_PROCESS_TIMEOUT_SECONDS=600

# Database
POSTGRES_DB=ai_erp_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ai_erp_assistant

# Object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-erp-uploads
MINIO_USE_SSL=false
OBJECT_STORAGE_REQUIRED=true
# ERP 后端调用源文件接口使用；生产环境必须生成独立高强度随机值。
SOURCE_FILE_API_TOKEN=

# ERP
ERP_CLIENT_MODE=real
ERP_BASE_URL=http://121.41.19.30:8080
ERP_WRITE_BASE_URL=http://121.41.19.30:8080
ERP_AUTH_MODE=bearer
ERP_API_TOKEN=
ERP_TIMEOUT_SECONDS=30
ERP_CREATE_TIMEOUT_SECONDS=120
ERP_CREATE_BODY_STYLE=datynk_sale_order
ERP_CREATE_DRAFT_PATH=/api/sale-order/save-with-details
ERP_SOURCE_ATTACHMENT_ENABLED=true
ERP_SOURCE_ATTACHMENT_MAX_BYTES=31457280
ERP_CUSTOMER_MATERIAL_DETAILS_BY_CUSTOMER_PATH=/api/customer-material/details-by-customer
ERP_ALLOW_EMPTY_DRAFT_URL=true
ERP_SKIP_UPSTREAM_VALIDATE=true
ERP_DATYNK_DEFAULT_ORG=英科1厂
ERP_CUSTOMER_PAGE_ENABLED=true
ERP_CUSTOMER_PAGE_PATH=/api/customer/page
ERP_CUSTOMER_PAGE_KEYWORD_PARAM=customerName
ERP_VENDORS_SEARCH_PATH=/api/supplier/page
ERP_VENDORS_SEARCH_QUERY_KEY=supplierName
ERP_MATERIALS_SEARCH_PATH=/api/material/page
ERP_WAREHOUSES_SEARCH_PATH=/api/warehouse/page
ERP_TAX_CODES_SEARCH_PATH=/api/tax/page
ERP_QA_FALLBACK_WHEN_NO_INTENT=true
ERP_CUSTOMER_SAVE_ENABLED=false

# LLM
LLM_API_KEY=sk-omgokfdaiyglzjcvmzgmqgwtxzdekqfrlbwxzkesfstktbqq
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
LLM_EXTRACT_ENABLED=true
ASSISTANT_LLM_ROUTER_ENABLED=true
LLM_TIMEOUT_SECONDS=120
LLM_EXTRACT_TIMEOUT_SECONDS=240
LLM_EXTRACT_CONTEXT_MAX_CHARS=12000
LLM_MAX_TOKENS=8192

# OCR
MINERU_ENABLED=true
MINERU_MODE=precise_v4
MINERU_PRECISE_API_BASE=https://mineru.net/api/v4
# MINERU_ENABLED=true 时必填；不要提交真实 Token。
MINERU_API_TOKEN=eyJ0eXBlIjoiSldUIiwiYWxnIjoiSFM1MTIifQ..8yNFrHBS4hpYQxwlhvj2Bp8ORPros3S4BbVbq6PwxbN2bEHPsj-b2NPPpuLIqFE2YcX0KWTsGGoShdTaeu0bXA
MINERU_MODEL_VERSION=vlm
MINERU_LANGUAGE=ch
MINERU_IS_OCR=true
MINERU_ENABLE_TABLE=true
MINERU_ENABLE_FORMULA=false
MINERU_HTTP_TIMEOUT_SECONDS=30
MINERU_POLL_TIMEOUT_SECONDS=180
MINERU_POLL_INTERVAL_SECONDS=3
OCR_ENGINE=rapid
OCR_ENGINE_AUTO_FALLBACK=true
RAPIDOCR_INTRA_OP_NUM_THREADS=2
RAPIDOCR_MIN_CONFIDENCE=0.78
OCR_HEALTH_INIT_RAPID=true
PADDLE_OCR_LANG=ch
PADDLE_OCR_USE_GPU=false
PDF_RENDER_DPI=250
PDF_NATIVE_MIN_CHARS=48
PDF_OCR_MAX_PAGES=10
TESSERACT_OCR_LANG=chi_sim+eng
