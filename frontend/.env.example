# 前端可见的环境变量必须以 NEXT_PUBLIC_ 开头
# 复制为 frontend/.env.local 后按需修改

# 推荐：不要设置此项。前端默认请求同源 `/api/orchestrator`，由 Next（next.config.mjs）转发到本机 FastAPI（见根目录 ORCHESTRATOR_PROXY_TARGET）。
# 这样用手机/局域网 IP 打开 http://x.x.x.x:3080（或你配置的 Next 端口）时也不会误连「设备本机 127.0.0.1」导致 Failed to fetch。
# 仅在生产或 API 与前端不同域时设置完整 URL，例如：
# NEXT_PUBLIC_API_BASE_URL=https://your-api.example.com

# 代理目标（仅 Next 服务端 rewrite 使用；一般无需改）：
# ORCHESTRATOR_PROXY_TARGET=http://127.0.0.1:8020

# 设为 1 时显示「开发辅助：手动调用内部 process 接口」按钮（仅本地联调用，勿在生产开启）
NEXT_PUBLIC_ENABLE_DEV_INTERNAL=0

# 可选：错误分类文案覆盖（JSON 字符串）
# 支持键：master_data / permission / timeout / upstream_error / default
# NEXT_PUBLIC_ERROR_CATEGORY_LABELS_JSON={"master_data":"主数据异常"}
# NEXT_PUBLIC_ERROR_CATEGORY_HINTS_JSON={"timeout":"上游超时，请稍后重试"}
